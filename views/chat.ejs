<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat - Textkro</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0a0a0f;
      color: white;
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.08;
      animation: float 8s ease-in-out infinite;
      z-index: 0;
    }
    .blob1 { width: 400px; height: 400px; background: #6c63ff; top: -100px; left: -100px; }
    .blob2 { width: 350px; height: 350px; background: #ff6b9d; bottom: -100px; right: -100px; animation-delay: 3s; }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }

    /* Navbar */
    nav {
      position: relative;
      z-index: 10;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      flex-shrink: 0;
    }

    .logo {
      font-size: 1.3rem;
      font-weight: 800;
      background: linear-gradient(135deg, #6c63ff, #48cae4);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      text-decoration: none;
    }

    .room-info {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
    }

    .room-id {
      font-size: 0.85rem;
      font-weight: 700;
      color: #a29bff;
    }

    .room-dot-row {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.72rem;
      color: #555;
    }

    .dot {
      width: 7px;
      height: 7px;
      background: #48cae4;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .exit-btn {
      text-decoration: none;
      color: #666;
      font-size: 0.85rem;
      border: 1px solid rgba(255,255,255,0.08);
      padding: 8px 16px;
      border-radius: 50px;
      transition: all 0.3s;
    }
    .exit-btn:hover { color: #ff6b9d; border-color: rgba(255,107,157,0.3); }

    /* Chat box */
    .chat-wrapper {
      position: relative;
      z-index: 5;
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .chat-wrapper::-webkit-scrollbar { width: 4px; }
    .chat-wrapper::-webkit-scrollbar-track { background: transparent; }
    .chat-wrapper::-webkit-scrollbar-thumb { background: rgba(108,99,255,0.3); border-radius: 10px; }

    /* Input area */
    .input-area {
      position: relative;
      z-index: 10;
      display: flex;
      gap: 0.8rem;
      padding: 1.2rem 2rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      flex-shrink: 0;
    }

    input {
      flex: 1;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 50px;
      padding: 14px 20px;
      color: white;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s;
    }

    input::placeholder { color: #444; }

    input:focus {
      border-color: #6c63ff;
      background: rgba(108,99,255,0.08);
      box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
    }

    #sendBtn {
      background: linear-gradient(135deg, #6c63ff, #48cae4);
      color: white;
      border: none;
      border-radius: 50px;
      padding: 14px 28px;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(108,99,255,0.3);
    }

    #sendBtn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(108,99,255,0.5);
    }
  </style>
</head>
<body>

  <div class="blob blob1"></div>
  <div class="blob blob2"></div>

  <!-- Navbar -->
  <nav>
    <a href="/" class="logo">💬 Textkro</a>
    <div class="room-info">
      <span class="room-id"> <%= roomId %></span>
      <div class="room-dot-row">
        <div class="dot"></div>
        <span>Live • <%= user.username %></span>
      </div>
    </div>
    <a href="/dashboard" class="exit-btn">🚪 Exit Room</a>
  </nav>

  <!-- Chat Messages -->
  <div class="chat-wrapper" id="chat-box"></div>

  <!-- Input -->
  <div class="input-area">
    <input type="text" id="message" placeholder="Kuch likho..." />
    <button id="sendBtn">Send </button>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();

    const roomId = "<%= roomId %>";
    const userId = "<%= user._id %>";
    const username = "<%= user.username %>";

    const chatBox = document.getElementById("chat-box");
    const messageInput = document.getElementById("message");
    const sendBtn = document.getElementById("sendBtn");

    socket.emit("join-room", { roomId, username });

    function getUserColor(username) {
      const colors = [
        "#FFB3B3", "#B3D9FF", "#B3FFB3", "#FFD9B3",
        "#E8B3FF", "#B3FFF0", "#FFF3B3", "#FFB3E6"
      ];
      let hash = 0;
      for (let i = 0; i < username.length; i++) {
        hash = username.charCodeAt(i) + ((hash << 5) - hash);
      }
      return colors[Math.abs(hash) % colors.length];
    }

    function addMessage(senderName, text) {
      const p = document.createElement("p");
      p.textContent = `${senderName}: ${text}`;
      p.style.backgroundColor = getUserColor(senderName);
      p.style.color = "#111";
      p.style.padding = "10px 16px";
      p.style.borderRadius = "12px";
      p.style.margin = "2px 0";
      p.style.fontSize = "0.95rem";
      p.style.maxWidth = "70%";
      p.style.wordBreak = "break-word";
      if (senderName === username) {
        p.style.alignSelf = "flex-end";
      } else {
        p.style.alignSelf = "flex-start";
      }
      chatBox.appendChild(p);
      chatBox.scrollTop = chatBox.scrollHeight;
    }

    socket.on("previous-messages", (messages) => {
      chatBox.innerHTML = "";
      messages.forEach(msg => {
        const senderName = msg.sender?.username || "Unknown";
        addMessage(senderName, msg.text);
      });
    });

    socket.on("user-joined", (data) => {
      const p = document.createElement("p");
      p.textContent = data.message;
      p.style.textAlign = "center";
      p.style.color = "#555";
      p.style.fontSize = "0.78rem";
      p.style.fontStyle = "italic";
      p.style.padding = "4px 0";
      p.style.alignSelf = "center";
      chatBox.appendChild(p);
      chatBox.scrollTop = chatBox.scrollHeight;
    });

    socket.on("receive-message", (data) => {
      addMessage(data.username, data.text);
    });

    sendBtn.addEventListener("click", () => {
      const text = messageInput.value.trim();
      if (!text) return;
      socket.emit("send-message", { roomId, userId, username, text });
      messageInput.value = "";
    });

    // Enter key se bhi send ho
    messageInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") sendBtn.click();
    });
  </script>

</body>
</html>