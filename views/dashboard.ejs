<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Textkro</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0a0a0f;
      color: white;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.12;
      animation: float 8s ease-in-out infinite;
      z-index: 0;
    }
    .blob1 { width: 400px; height: 400px; background: #6c63ff; top: -100px; left: -100px; }
    .blob2 { width: 350px; height: 350px; background: #ff6b9d; bottom: -100px; right: -100px; animation-delay: 3s; }
    .blob3 { width: 300px; height: 300px; background: #48cae4; top: 40%; left: 40%; animation-delay: 5s; }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }

    /* Navbar */
    nav {
      position: relative;
      z-index: 10;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
    }

    .logo {
      font-size: 1.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, #6c63ff, #48cae4);
      -webkit-background-clip: text;
      background-clip: text;  
      -webkit-text-fill-color: transparent;
    }

    .logout-btn {
      text-decoration: none;
      color: #666;
      font-size: 0.85rem;
      border: 1px solid rgba(255,255,255,0.08);
      padding: 8px 18px;
      border-radius: 50px;
      transition: all 0.3s;
    }
    .logout-btn:hover { color: #ff6b9d; border-color: rgba(255,107,157,0.3); }

    /* Main */
    .main {
      position: relative;
      z-index: 5;
      max-width: 600px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    .welcome {
      margin-bottom: 3rem;
    }

    .welcome p {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 0.3rem;
    }

    .welcome h1 {
      font-size: 2.2rem;
      font-weight: 800;
    }

    .welcome h1 span {
      background: linear-gradient(135deg, #6c63ff, #48cae4);
      -webkit-background-clip: text;
      background-clip: text;  
      -webkit-text-fill-color: transparent;
    }

    /* Cards */
    .card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px;
      padding: 2rem;
      margin-bottom: 1.5rem;
      backdrop-filter: blur(20px);
      transition: border-color 0.3s;
    }

    .card:hover { border-color: rgba(108,99,255,0.25); }

    .card-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-desc {
      font-size: 0.85rem;
      color: #555;
      margin-bottom: 1.5rem;
    }

    .btn-primary {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #6c63ff, #48cae4);
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 8px 25px rgba(108,99,255,0.3);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 35px rgba(108,99,255,0.5);
    }

    .input-row {
      display: flex;
      gap: 0.8rem;
    }

    input {
      flex: 1;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 14px 16px;
      color: white;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s;
    }

    input::placeholder { color: #444; }

    input:focus {
      border-color: #6c63ff;
      background: rgba(108,99,255,0.08);
      box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
    }

    .btn-secondary {
      padding: 14px 20px;
      background: rgba(108,99,255,0.15);
      color: #a29bff;
      border: 1px solid rgba(108,99,255,0.25);
      border-radius: 12px;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
      white-space: nowrap;
    }

    .btn-secondary:hover {
      background: rgba(108,99,255,0.25);
      transform: translateY(-2px);
    }
  </style>
</head>
<body>

  <div class="blob blob1"></div>
  <div class="blob blob2"></div>
  <div class="blob blob3"></div>

<nav>
  <a href="/" class="logo">💬 Textkro</a>
  <a href="/logout" class="logout-btn">🚪 Logout</a>
</nav>

  <div class="main">

    <div class="welcome">
      <p>Welcome 👋</p>
      <h1>Welcome, <span><%= user.username %></span></h1>
    </div>

    <!-- Create Room -->
    <div class="card">
      <div class="card-title">🚀 Create a New Room</div>
      <div class="card-desc">Start a new chat room and invite your friends.</div>
      <form action="/create-room" method="POST">
        <button type="submit" class="btn-primary">+ Create Room</button>
      </form>
    </div>

    <!-- Join Room -->
    <div class="card">
      <div class="card-title">🔗 Join a Room</div>
      <div class="card-desc">Join an existing room by entering its Room ID.</div>
      <form action="/join-room" method="POST">
        <div class="input-row">
          <input type="text" name="roomId" placeholder="Enter Room ID..." required />
          <button type="submit" class="btn-secondary">Join →</button>
        </div>
      </form>
    </div>

  </div>

</body>
</html>